{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "es2022",
    "lib": ["es2022"],
    "types": ["node"],
    "esModuleInterop": true,
    "declaration": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "sourceMap": true,
    "newLine": "LF",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "incremental": true,
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
    "strict": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
